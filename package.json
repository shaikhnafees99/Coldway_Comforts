{
  "name": "coldway-comforts-website",
  "version": "1.0.0",
  "private": true,
  "description": "Static SEO website for Coldway Comforts with GitHub Pages deployment workflow.",
  "scripts": {
    "build": "echo 'Static website ready in repository root.'",
    "build:sitemaps": "node scripts/build-sitemaps.mjs",
    "seo:consolidate": "node scripts/consolidate-location-pages.mjs",
    "seo:commercial": "node scripts/enhance-commercial-page.mjs",
    "seo:areas": "node scripts/generate-genuine-areas.mjs",
    "seo:guides": "node scripts/generate-guides.mjs",
    "pages:count": "find . -name '*.html' -not -path './.git/*' | wc -l",
    "test:site": "node scripts/check-site.mjs"
  }
}
